# ===========================================
# Think Space Environment Configuration
# ===========================================

# Application
NODE_ENV=development
SITE_URL=http://localhost:3000

# ===========================================
# Next.js (apps/web)
# ===========================================
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# ===========================================
# Elysia API (apps/api)
# ===========================================
PORT=3001
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# JWT
JWT_SECRET=your-jwt-secret-change-in-production-min-32-chars

# ===========================================
# Strapi CMS (apps/cms)
# ===========================================
STRAPI_HOST=0.0.0.0
STRAPI_PORT=1337
STRAPI_PUBLIC_URL=http://localhost:1337

# Strapi Security Keys (generate with: openssl rand -base64 32)
APP_KEYS=key1,key2,key3,key4
API_TOKEN_SALT=your-api-token-salt
ADMIN_JWT_SECRET=your-admin-jwt-secret
TRANSFER_TOKEN_SALT=your-transfer-token-salt

# ===========================================
# Database (Supabase/PostgreSQL)
# ===========================================
DATABASE_CLIENT=postgres
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_NAME=thinkspace
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=your-postgres-password-change-me
DATABASE_SSL=false

# Full connection string (alternative)
DATABASE_URL=postgres://postgres:your-postgres-password-change-me@db:5432/thinkspace

# ===========================================
# Supabase
# ===========================================
SUPABASE_URL=http://localhost:8000
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret-with-at-least-32-characters

# GoTrue (Auth)
GOTRUE_JWT_SECRET=your-jwt-secret-with-at-least-32-characters
GOTRUE_JWT_EXP=3600
GOTRUE_SITE_URL=http://localhost:3000
GOTRUE_MAILER_AUTOCONFIRM=true

# ===========================================
# Redis
# ===========================================
REDIS_URL=redis://redis:6379

# ===========================================
# Meilisearch
# ===========================================
MEILISEARCH_HOST=http://meilisearch:7700
MEILISEARCH_API_KEY=your-meilisearch-master-key

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key
FROM_EMAIL=noreply@thinkspace.com
ADMIN_EMAIL=admin@thinkspace.com

# ===========================================
# Webhooks
# ===========================================
WEBHOOK_SECRET=your-webhook-secret-for-strapi-webhooks
REVALIDATE_SECRET=your-revalidate-secret-for-isr

# ===========================================
# CORS
# ===========================================
CORS_ORIGINS=http://localhost:3000,http://localhost:1337
