      "type": "enumeration",
      "enum": ["Target", "Award", "Users", "Globe", "Lightbulb", "Shield", "Rocket", "Heart"],
      "required": true,
      "default": "Target"
    },
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    },
    "description": {
      "type": "text",
      "required": true,
      "pluginOptions": {
        "i18n": {
          "localized": true
        }
      }
    }
  }
}
