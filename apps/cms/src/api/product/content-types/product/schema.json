{
  "kind": "collectionType",
  "collectionName": "products",
  "info": {
    "singularName": "product",
    "pluralName": "products",
    "displayName": "Product",
    "description": "Flagship products (Logix, Proxmox reseller) shown under /products"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "slug": {
      "type": "uid",
      "targetField": "name",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "kind": {
      "type": "enumeration",
      "enum": ["proxmox", "logix", "generic"],
      "default": "generic"
    },
    "order": {
      "type": "integer",
      "default": 0
    },
    "eyebrow": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "title": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "titleHighlight": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "intro": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "ctaLabel": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "heroChips": {
      "type": "json"
    },
    "features": {
      "type": "component",
      "repeatable": true,
      "component": "product.feature",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "tiers": {
      "type": "component",
      "repeatable": true,
      "component": "product.tier",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "addOns": {
      "type": "component",
      "repeatable": true,
      "component": "product.add-on",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "extra": {
      "type": "json",
      "pluginOptions": { "i18n": { "localized": true } }
    }
  }
}
