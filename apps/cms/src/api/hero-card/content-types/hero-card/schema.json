{
  "kind": "collectionType",
  "collectionName": "hero_cards",
  "info": {
    "singularName": "hero-card",
    "pluralName": "hero-cards",
    "displayName": "Hero Card",
    "description": "Cards in the homepage hero accordion — pillars, products, news, etc."
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {
    "i18n": {
      "localized": true
    }
  },
  "attributes": {
    "title": {
      "type": "string",
      "required": true,
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "caption": {
      "type": "text",
      "pluginOptions": { "i18n": { "localized": true } }
    },
    "image": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "background": {
      "type": "media",
      "multiple": false,
      "required": false,
      "allowedTypes": ["images", "videos"],
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "icon": {
      "type": "enumeration",
      "enum": ["Cpu", "ShieldCheck", "Server", "Boxes", "Sparkles", "Newspaper", "Package", "Cloud", "Database", "Code", "Cog", "Rocket", "Layers", "BrainCircuit"],
      "default": "Sparkles",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "linkUrl": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "accentColor": {
      "type": "string",
      "pluginOptions": { "i18n": { "localized": false } }
    },
    "order": {
      "type": "integer",
      "default": 0,
      "pluginOptions": { "i18n": { "localized": false } }
    }
  }
}
