async function createWork(work: WorkData) {
  const headers = {
    'Content-Type': 'application/json',
    'Authorization': `Bearer ${API_TOKEN}`,
  };

  // Create Thai version first (default locale)
  const thData = {
    data: {
      title: work.title.th,
      slug: work.slug,
      clientName: work.clientName,
      industry: work.industry.th,
      excerpt: work.excerpt.th,
      challenge: work.challenge.th,
      solution: work.solution.th,
      resultValue: work.resultValue,
      resultLabel: work.resultLabel.th,
    },
  };

  console.log(`Creating Thai version of ${work.slug}...`);

  const thResponse = await fetch(`${STRAPI_URL}/api/case-studies`, {
    method: 'POST',
    headers,
    body: JSON.stringify(thData),
  });

  if (!thResponse.ok) {
    const error = await thResponse.text();
    console.error(`Failed to create Thai ${work.slug}:`, error);
    return null;
  }

  const thResult = await thResponse.json() as { data: { documentId: string } };
  const documentId = thResult.data.documentId;
  console.log(`Created Thai ${work.slug} with documentId: ${documentId}`);

  // Publish Thai version
  await fetch(`${STRAPI_URL}/api/case-studies/${documentId}/actions/publish`, {
    method: 'POST',
    headers,
  });
  console.log(`Published Thai ${work.slug}`);

  // Create English localization
  const enData = {
    data: {
      title: work.title.en,
      slug: work.slug,
      clientName: work.clientName,
      industry: work.industry.en,
      excerpt: work.excerpt.en,
      challenge: work.challenge.en,
      solution: work.solution.en,
      resultValue: work.resultValue,
      resultLabel: work.resultLabel.en,
    },
  };

  console.log(`Creating English version of ${work.slug}...`);

  const enResponse = await fetch(`${STRAPI_URL}/api/case-studies/${documentId}?locale=en`, {
    method: 'PUT',
    headers,
    body: JSON.stringify(enData),
  });

  if (!enResponse.ok) {
    const error = await enResponse.text();
    console.error(`Failed to create English ${work.slug}:`, error);
    return documentId;
  }

  console.log(`Created English ${work.slug}`);

  // Publish English version
  await fetch(`${STRAPI_URL}/api/case-studies/${documentId}/actions/publish?locale=en`, {
    method: 'POST',
    headers,
  });
  console.log(`Published English ${work.slug}\n`);

  return documentId;
}

async function main() {
  if (!API_TOKEN) {
    console.error('Error: STRAPI_API_TOKEN is not set');
    process.exit(1);
  }

  console.log('Seeding Works (Case Studies) data...\n');

  for (const work of worksData) {
    await createWork(work);
  }

  console.log('Seeding complete!');
}

main().catch(console.error);
