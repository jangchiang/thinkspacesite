async function createService(service: ServiceData, order: number) {
  const headers = {
    'Content-Type': 'application/json',
    'Authorization': `Bearer ${API_TOKEN}`,
  };

  // Create Thai version first (default locale)
  const thData = {
    data: {
      title: service.titleTh,
      slug: service.slug,
      description: service.descriptionTh,
      shortDescription: service.descriptionTh,
      icon: service.icon,
      color: service.color,
      order: order,
      features: service.features.map(f => ({ title: f.th })),
      useCases: service.useCases.map(uc => ({ title: uc.th.title, description: uc.th.description })),
      technologies: service.technologies.map(t => ({ name: t })),
      processSteps: service.process.map(p => ({ title: p.th.title, description: p.th.description })),
    },
  };

  console.log(`Creating Thai version of ${service.slug}...`);

  const thResponse = await fetch(`${STRAPI_URL}/api/services`, {
    method: 'POST',
    headers,
    body: JSON.stringify(thData),
  });

  if (!thResponse.ok) {
    const error = await thResponse.text();
    console.error(`Failed to create Thai ${service.slug}:`, error);
    return null;
  }

  const thResult = await thResponse.json() as { data: { documentId: string } };
  const documentId = thResult.data.documentId;
  console.log(`Created Thai ${service.slug} with documentId: ${documentId}`);

  // Create English version
  const enData = {
    data: {
      title: service.titleEn,
      slug: service.slug,  // Include slug for English version
      description: service.descriptionEn,
      shortDescription: service.descriptionEn,
      icon: service.icon,
      color: service.color,
      order: order,
      features: service.features.map(f => ({ title: f.en })),
      useCases: service.useCases.map(uc => ({ title: uc.en.title, description: uc.en.description })),
      technologies: service.technologies.map(t => ({ name: t })),
      processSteps: service.process.map(p => ({ title: p.en.title, description: p.en.description })),
    },
  };

  console.log(`Creating English version of ${service.slug}...`);

  const enResponse = await fetch(`${STRAPI_URL}/api/services/${documentId}?locale=en`, {
    method: 'PUT',
    headers,
    body: JSON.stringify(enData),
  });

  if (!enResponse.ok) {
    const error = await enResponse.text();
    console.error(`Failed to create English ${service.slug}:`, error);
  } else {
    console.log(`Created English ${service.slug}`);
  }

  // Publish both versions
  console.log(`Publishing ${service.slug}...`);

  await fetch(`${STRAPI_URL}/api/services/${documentId}/actions/publish?locale=th-TH`, {
    method: 'POST',
    headers,
  });

  await fetch(`${STRAPI_URL}/api/services/${documentId}/actions/publish?locale=en`, {
    method: 'POST',
    headers,
  });

  console.log(`Published ${service.slug}\n`);

  return documentId;
}

async function main() {
  if (!API_TOKEN) {
    console.error('Error: STRAPI_API_TOKEN environment variable is not set');
    console.log('Please create a Full Access API token in Strapi admin:');
    console.log('Settings > API Tokens > Create new token');
    console.log('Then run: STRAPI_API_TOKEN=your_token npx ts-node scripts/seed-services.ts');
    process.exit(1);
  }

  console.log('Starting service migration to Strapi...\n');

  for (let i = 0; i < services.length; i++) {
    await createService(services[i], i);
  }

  console.log('Migration complete!');
}

main().catch(console.error);
