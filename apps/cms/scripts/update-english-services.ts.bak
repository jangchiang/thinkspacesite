async function updateEnglishService(service: ServiceUpdate) {
  const headers = {
    'Content-Type': 'application/json',
    'Authorization': `Bearer ${API_TOKEN}`,
  };

  const data = {
    data: {
      title: service.titleEn,
      slug: service.slug,
      description: service.descriptionEn,
      shortDescription: service.descriptionEn,
      icon: service.icon,
      color: service.color,
      order: service.order,
      features: service.features.map(f => ({ title: f })),
      useCases: service.useCases.map(uc => ({ title: uc.title, description: uc.description })),
      technologies: service.technologies.map(t => ({ name: t })),
      processSteps: service.processSteps.map(ps => ({ title: ps.title, description: ps.description })),
    },
  };

  console.log(`Updating English version of ${service.slug}...`);

  const response = await fetch(`${STRAPI_URL}/api/services/${service.documentId}?locale=en`, {
    method: 'PUT',
    headers,
    body: JSON.stringify(data),
  });

  if (!response.ok) {
    const error = await response.text();
    console.error(`Failed to update ${service.slug}:`, error);
    return false;
  }

  console.log(`Updated English ${service.slug}`);

  // Publish
  await fetch(`${STRAPI_URL}/api/services/${service.documentId}/actions/publish?locale=en`, {
    method: 'POST',
    headers,
  });

  console.log(`Published English ${service.slug}\n`);
  return true;
}

async function main() {
  if (!API_TOKEN) {
    console.error('Error: STRAPI_API_TOKEN is not set');
    process.exit(1);
  }

  console.log('Updating English versions of services...\n');

  for (const service of updates) {
    await updateEnglishService(service);
  }

  console.log('Update complete!');
}

main().catch(console.error);
