# ===========================================
# Think Space - Production Environment
# Domain: techthinkspace.com
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# General
# ===========================================
NODE_ENV=production

# ===========================================
# URLs
# ===========================================
NEXT_PUBLIC_SITE_URL=https://techthinkspace.com
NEXT_PUBLIC_API_URL=https://techthinkspace.com/api
NEXT_PUBLIC_STRAPI_URL=https://cms.techthinkspace.com
STRAPI_PUBLIC_URL=https://cms.techthinkspace.com
STRAPI_URL=http://cms:1337

# ===========================================
# Database - PostgreSQL
# ===========================================
POSTGRES_USER=thinkspace
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD_123!
POSTGRES_DB=thinkspace

# ===========================================
# Strapi CMS Security Keys
# Generate with: openssl rand -base64 32
# ===========================================
STRAPI_APP_KEYS=key1_base64,key2_base64,key3_base64,key4_base64
STRAPI_API_TOKEN_SALT=GENERATE_WITH_OPENSSL_RAND_BASE64_32
STRAPI_ADMIN_JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32
STRAPI_TRANSFER_TOKEN_SALT=GENERATE_WITH_OPENSSL_RAND_BASE64_32
STRAPI_JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# Strapi API Token (create in Strapi admin panel)
STRAPI_API_TOKEN=your-strapi-api-token

# ===========================================
# JWT Secret (for API)
# ===========================================
JWT_SECRET=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# ===========================================
# Meilisearch
# ===========================================
MEILISEARCH_KEY=GENERATE_STRONG_MASTER_KEY
MEILI_ENV=production

# ===========================================
# Translation (Groq AI)
# ===========================================
GROQ_API_KEY=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

# ===========================================
# Email (Resend)
# ===========================================
RESEND_API_KEY=re_your_resend_api_key
CONTACT_EMAIL=contact@techthinkspace.com

# ===========================================
# Webhooks & Revalidation
# ===========================================
REVALIDATION_SECRET=GENERATE_RANDOM_SECRET

# ===========================================
# CORS (comma-separated domains)
# ===========================================
CORS_ORIGINS=https://techthinkspace.com,https://www.techthinkspace.com,https://cms.techthinkspace.com
